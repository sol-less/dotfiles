include colors-matugen.conf

# =========================
# FONT
# =========================
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
font_size        11

# enable ligatures (because you code and wanna feel cool)
disable_ligatures never

# =========================
# CURSOR
# =========================
cursor_blink_interval 0.5

# =========================
# WINDOW LOOK
# =========================
background_opacity 0.6
dynamic_background_opacity yes

shell_integration no-cursor
shell_integration enabled
cursor_shape block
cursor_blink_interval 0


# blur (works nice on wayland/hyprland)
background_blur 50

# padding so it doesn’t look like a cramped cave
window_padding_width 20

# no ugly borders
hide_window_decorations yes

# =========================
# SCROLLING
# =========================
scrollback_lines 10000
wheel_scroll_multiplier 5.0

# smooth scrolling because we are civilized creatures
smooth_scroll yes

# =========================
# PERFORMANCE
# =========================
enable_audio_bell no
visual_bell_duration 0.0
repaint_delay 10
input_delay 3
