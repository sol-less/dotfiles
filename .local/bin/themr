#!/bin/bash

options="๓ฐฌบ    Black\n๓ฐฌป    Blue\n๓ฐฌผ    Cozy\n๓ฐฌฝ    Neutral\n๓ฐฌพ    Others"

choice=$(echo -e "$options" | rofi -dmenu -i -p "๏€พ  " -theme-str ' entry { placeholder: "Theme.."; }' -no-show-icons)

case $choice in
*"Black")
  ./.local/bin/themeholder/black
  ;;

*"Blue")
  ./.local/bin/themeholder/blue
  ;;

*"Cozy")
  ./.local/bin/themeholder/cozy
  ;;

*"Neutral")
  ./.local/bin/themeholder/neutral
  ;;

*"Others")
  ./.local/bin/themeholder/others
  ;;
esac
